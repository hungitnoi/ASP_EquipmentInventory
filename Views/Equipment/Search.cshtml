@model IEnumerable<EquipmentInventory.Models.Equipment>

<h2>Tìm kiếm thiết bị</h2>

<form asp-controller="Equipment" asp-action="Search" method="get" class="mb-4 d-flex gap-2">
    <input type="text" name="Keyword" class="form-control" placeholder="Tên thiết bị..." value="@ViewBag.SearchModel.Keyword" />
    <input type="text" name="Category" class="form-control" placeholder="Danh mục..." value="@ViewBag.SearchModel.Category" />
    <input type="number" name="MinPrice" class="form-control" placeholder="Giá tối thiểu..." value="@ViewBag.SearchModel.MinPrice" />
    <button type="submit" class="btn btn-primary">Tìm</button>
</form>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <partial name="_EquipmentCard" model="item" />
        </div>
    }
</div>